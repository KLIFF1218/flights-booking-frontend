# Copy this file to .env and fill in the actual values:
#   cp .env.example .env

# Dev server port (must be listed in backend HTTP_CORS)
PORT=3111

# Backend API base URL (includes /api/v1 prefix)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# VK ID app ID (same value as backend VK_CLIENT_ID)
NEXT_PUBLIC_VK_APP_ID=YOUR_VK_APP_ID

# VK OAuth redirect URL (must match VK app settings and backend VK_REDIRECT_URI)
NEXT_PUBLIC_VK_REDIRECT_URL=http://localhost:3111
